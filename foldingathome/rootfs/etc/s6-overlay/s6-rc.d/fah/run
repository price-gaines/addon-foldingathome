#!/command/with-contenv bashio
# shellcheck shell=bash
# shellcheck disable=SC2191
# ==============================================================================
# Home Assistant Community Add-on: Folding@home
# Runs the FAHClient
# ==============================================================================
declare -a options

bashio::log.info 'Starting Folding@home...'

ACCOUNT_TOKEN="$(bashio::config 'account_token')"
MACHINE_NAME="$(bashio::config 'machine_name')"

FAH_USER="$(bashio::config 'user')"
FAH_TEAM="$(bashio::config 'team')"
FAH_PASSKEY="$(bashio::config 'passkey')"

# Required-field guard: this build will not start unless all required fields are provided.
missing=()

if [[ -z "${FAH_USER}" ]]; then
  missing+=("user")
fi

if [[ -z "${FAH_PASSKEY}" ]]; then
  missing+=("passkey")
fi

if [[ -z "${ACCOUNT_TOKEN}" ]]; then
  missing+=("account_token")
fi

if [[ -z "${MACHINE_NAME}" ]]; then
  missing+=("machine_name")
fi

if [[ -z "${FAH_TEAM}" ]]; then
  missing+=("team")
fi

if (( ${#missing[@]} > 0 )); then
  bashio::log.error "Missing required configuration value(s): ${missing[*]}"
  bashio::log.error "Fill in all required fields in the add-on Configuration tab, save, then start the add-on again."
  bashio::exit.nok
fi

options+=(--http-addresses 0.0.0.0:7396)
options+=(--allow 0/0)

options+=(--user "${FAH_USER}")
options+=(--team "${FAH_TEAM}")

options+=(--passkey "${FAH_PASSKEY}")


cd /data || bashio::exit.nok "Failed to change to working directory"

CONFIG_FILE="/data/config.xml"

xml_escape() {
  local value="$1"
  value=${value//&/&amp;}
  value=${value//</&lt;}
  value=${value//>/&gt;}
  value=${value//\"/&quot;}
  value=${value//\'/&apos;}
  printf '%s' "${value}"
}

# Write config.xml for account linking.
bashio::log.info "Writing ${CONFIG_FILE} (account linked)"
tmp_config="$(mktemp /data/config.xml.XXXXXX)" || {
  bashio::log.error "Failed to create temporary config file"
  bashio::exit.nok
}

{
  echo "<config>"
  echo "  <account-token v=\"$(xml_escape "${ACCOUNT_TOKEN}")\"/>"
  echo "  <machine-name v=\"$(xml_escape "${MACHINE_NAME}")\"/>"
  echo "</config>"
} > "${tmp_config}" || {
  bashio::log.error "Failed to write temporary config file: ${tmp_config}"
  rm -f "${tmp_config}"
  bashio::exit.nok
}

chmod 600 "${tmp_config}" || {
  bashio::log.error "Failed to set permissions on temporary config file: ${tmp_config}"
  rm -f "${tmp_config}"
  bashio::exit.nok
}

mv -f "${tmp_config}" "${CONFIG_FILE}" || {
  bashio::log.error "Failed to replace ${CONFIG_FILE}"
  rm -f "${tmp_config}"
  bashio::exit.nok
}

# Log args, but redact passkey to avoid leaking secrets into add-on logs
log_args=()
skip_next=false
for arg in "${options[@]}"; do
  if ${skip_next}; then
    log_args+=("********")
    skip_next=false
    continue
  fi

  if [[ "${arg}" == "--passkey" ]]; then
    log_args+=("--passkey")
    skip_next=true
    continue
  fi

  log_args+=("${arg}")
done

bashio::log.info "FAHClient args: ${log_args[*]}"
exec /usr/bin/FAHClient "${options[@]}"
